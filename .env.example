# .env.example — SYNAPSE Backend Environment Variables
# Copy to services/api/.env and fill in your values.
# Lines starting with # are comments / explanations.
# Never commit the actual .env file to version control.

# ─────────────────────────────────────────────────────────────────────────────
# AI — Gemini (required)
# Get from: https://aistudio.google.com → API Keys
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Firebase Admin SDK (required)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate key
# Dev: path to JSON file
# Railway: paste JSON content as FIREBASE_CREDENTIALS_JSON env var instead
# ─────────────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=synapse-platform-prod
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ─────────────────────────────────────────────────────────────────────────────
# Supabase Storage (required — replaces Cloudinary + Firebase Storage)
# Get from: supabase.com → Project Settings → API
# Use the service_role key (not the anon key) for server-side uploads
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_service_role_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Maps & Location — all open-source, no API keys needed
# Only override these if self-hosting any of these services
# ─────────────────────────────────────────────────────────────────────────────
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OSRM_BASE_URL=http://router.project-osrm.org
OVERPASS_BASE_URL=https://overpass-api.de/api

# ─────────────────────────────────────────────────────────────────────────────
# Email — Resend (required — replaces Gmail API)
# Get from: resend.com → API Keys
# Free tier: 3,000 emails/month
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=noreply@synapse.example.com

# ─────────────────────────────────────────────────────────────────────────────
# Translation — LibreTranslate (replaces Cloud Translation API)
# Option A (recommended for demo): use the public endpoint below (free, no key)
# Option B: self-host LibreTranslate on Railway for production use
# ─────────────────────────────────────────────────────────────────────────────
LIBRETRANSLATE_URL=https://libretranslate.com
# LIBRETRANSLATE_API_KEY=   # only needed for libretranslate.com paid tier

# ─────────────────────────────────────────────────────────────────────────────
# Whisper — OpenAI Whisper runs locally, no API key needed
# Model size: "base" (good speed/accuracy balance for Indian languages)
# Pre-download: python -c "import whisper; whisper.load_model('base')"
# ─────────────────────────────────────────────────────────────────────────────
WHISPER_MODEL=base

# ─────────────────────────────────────────────────────────────────────────────
# Application settings
# ─────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
PORT=8080
LOG_LEVEL=INFO
WEB_APP_URL=http://localhost:3000
DONOR_APP_URL=http://localhost:3001

# Rural districts — 1.3× urgency boost (bottom quartile remoteness index)
RURAL_DISTRICT_CODES=KA-KODAGU,KA-CHIKMAGALUR,KA-SHIVAMOGGA

# ─────────────────────────────────────────────────────────────────────────────
# REMOVED KEYS (do not add these back):
#   CLOUDINARY_CLOUD_NAME     → replaced by SUPABASE_URL + SUPABASE_KEY
#   CLOUDINARY_API_KEY        → replaced by SUPABASE_URL + SUPABASE_KEY
#   CLOUDINARY_API_SECRET     → replaced by SUPABASE_URL + SUPABASE_KEY
#   GOOGLE_MAPS_API_KEY       → replaced by Leaflet + OpenStreetMap (no key needed)
#   GOOGLE_CLOUD_API_KEY      → replaced by pytesseract, Whisper, LibreTranslate
# ─────────────────────────────────────────────────────────────────────────────
