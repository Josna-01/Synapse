# ==============================================================================
# SYNAPSE - Environment Variables Template
# ==============================================================================
# Copy this file to `.env` and fill in your actual API keys.
# DO NOT commit your actual `.env` file to Git!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Google Model Context Protocol (Google ADK / Gemini)
# ------------------------------------------------------------------------------
# Required for Urgency Scoring, Deduplication, OCR Extraction, and Impact Generation.
GEMINI_API_KEY="your_gemini_api_key_here"
GOOGLE_APPLICATION_CREDENTIALS="./firebase-service-account.json"  # Path to Google Cloud Service Account

# ------------------------------------------------------------------------------
# 2. Firebase & Firestore
# ------------------------------------------------------------------------------
# Required for Real-time database, Authentication, and FCM Push Notifications
FIREBASE_PROJECT_ID="synapse-platform-prod"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@synapse-platform-prod.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Key_Here\n-----END PRIVATE KEY-----"

# ------------------------------------------------------------------------------
# 3. Notification & Messaging Fallbacks
# ------------------------------------------------------------------------------
# Resend (Email Fallback for Volunteer Push + Gov Digest + Donor Updates)
RESEND_API_KEY="re_your_resend_api_key_here"

# WhatsApp Cloud API (For Intake / Fallback conversational bot)
WHATSAPP_API_TOKEN="your_whatsapp_cloud_api_token"
WHATSAPP_PHONE_ID="your_whatsapp_phone_number_id"

# ------------------------------------------------------------------------------
# 4. Storage (Supabase)
# ------------------------------------------------------------------------------
# Required for storing images (survey photos) and generated PDF reports
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_key"

# ------------------------------------------------------------------------------
# 5. Geocoding & Routing (Local APIs usually don't need keys, but defining URLs is good practice)
# ------------------------------------------------------------------------------
OSRM_BASE_URL="http://router.project-osrm.org"
NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org"

# ------------------------------------------------------------------------------
# 6. Next.js Frontend Configuration
# ------------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN="" # Optional if using Mapbox instead of raw Leaflet/OSM
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
